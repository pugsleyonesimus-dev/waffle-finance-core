{
  "name": "@wafflefinance/relayer",
  "version": "1.0.0",
  "description": "Event relay service for the WaffleFinance cross-chain bridge",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@wafflefinance/config": "workspace:*",
    "@stellar/stellar-sdk": "^13.0.0",
    "@types/node": "^22.10.0",
    "axios": "^1.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "prom-client": "^15.1.3",
    "typescript": "^5.6.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "supertest": "^7.2.2",
    "tsx": "^4.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "relayer",
    "ethereum",
    "stellar",
    "solana",
    "cross-chain"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
