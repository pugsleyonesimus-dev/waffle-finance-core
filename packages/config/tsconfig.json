{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "noFallthroughCasesInSwitch": true,
    "types": ["node"],
    "moduleResolution": "Bundler",
